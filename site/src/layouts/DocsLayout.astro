---
import Base from './Base.astro';
import { withBase } from '../lib/paths';

interface Props {
  title: string;
  description: string;
  eyebrow?: string;
}
const { title, description, eyebrow } = Astro.props;
const path = Astro.url.pathname.replace(/\/$/, '');

const docs = [
  { href: '/docs/architecture', label: 'Architecture' },
  { href: '/docs/safety', label: 'Safety' },
  { href: '/docs/evaluation', label: 'Evaluation' },
  { href: '/docs/cli', label: 'CLI reference' },
  { href: '/docs/contributing', label: 'Contributing' },
];
const isActive = (href: string) => path.endsWith(href);
---

<Base title={title} description={description}>
  <div class="wrap docs-grid">
    <aside class="docs-side">
      <nav aria-label="Documentation">
        <p class="docs-side-title">Docs</p>
        <ul>
          {docs.map((d) => (
            <li>
              <a href={withBase(d.href)} aria-current={isActive(d.href) ? 'page' : undefined}>
                {d.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </aside>

    <article class="docs-article">
      <header class="docs-head">
        {eyebrow && <p class="eyebrow">{eyebrow}</p>}
        <h1>{title}</h1>
        <p class="lede">{description}</p>
      </header>
      <slot />
    </article>
  </div>
</Base>

<style>
  .docs-grid {
    display: grid;
    grid-template-columns: 15rem minmax(0, 1fr);
    gap: 3rem;
    padding-top: var(--space-4);
    align-items: start;
  }

  .docs-side {
    position: sticky;
    top: 88px;
  }

  .docs-side-title {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-muted);
    margin: 0 0 0.7rem;
    padding-left: 0.7rem;
  }

  .docs-side ul {
    list-style: none;
    margin: 0;
    padding: 0;
    border-left: 1px solid var(--border);
  }

  .docs-side li {
    margin: 0;
  }

  .docs-side a {
    display: block;
    padding: 0.45rem 0.7rem;
    margin-left: -1px;
    border-left: 2px solid transparent;
    color: var(--ink-muted);
    font-size: 0.95rem;
    font-weight: 500;
    text-decoration: none;
  }

  .docs-side a:hover {
    color: var(--ink);
  }

  .docs-side a[aria-current='page'] {
    color: var(--teal-deep);
    border-left-color: var(--teal);
    font-weight: 600;
  }

  .docs-article {
    min-width: 0;
  }

  .docs-head {
    margin-bottom: var(--space-3);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--border);
  }

  .docs-head h1 {
    margin-bottom: 0.4rem;
  }

  .docs-head .lede {
    margin-bottom: 0;
  }

  @media (max-width: 900px) {
    .docs-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .docs-side {
      position: static;
    }
    .docs-side ul {
      display: flex;
      flex-wrap: wrap;
      border-left: 0;
      gap: 0.3rem;
    }
    .docs-side a {
      border-left: 0;
      border-radius: 999px;
      padding: 0.35rem 0.8rem;
      background: var(--cream-2);
    }
    .docs-side a[aria-current='page'] {
      background: var(--peach);
    }
  }
</style>
