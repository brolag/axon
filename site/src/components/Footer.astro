---
import { withBase } from '../lib/paths';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="wrap footer-inner">
    <div class="footer-brand">
      <span class="footer-name">axon</span>
      <p class="muted footer-tag">The wiring that makes a local model think and act.</p>
    </div>
    <nav class="footer-nav" aria-label="Footer">
      <a href={withBase('/docs/architecture')}>Architecture</a>
      <a href={withBase('/docs/safety')}>Safety</a>
      <a href={withBase('/docs/evaluation')}>Evaluation</a>
      <a href={withBase('/docs/cli')}>CLI</a>
      <a href={withBase('/docs/contributing')}>Contributing</a>
      <a href="https://github.com/brolag/axon" rel="noopener">GitHub</a>
    </nav>
  </div>
  <div class="wrap footer-meta">
    <small>Apache-2.0. Built by Alfredo Bonilla / Indie Mind. &copy; {year}.</small>
    <small>A study in AI engineering: a managed Google brain rebuilt from open Google parts.</small>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    background: var(--cream-2);
    margin-top: var(--space-6);
    padding: var(--space-4) 0 var(--space-3);
  }

  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    align-items: flex-start;
    justify-content: space-between;
  }

  .footer-name {
    font-weight: 700;
    font-size: 1.1rem;
  }

  .footer-tag {
    margin: 0.3rem 0 0;
    max-width: 22rem;
    font-size: 0.95rem;
  }

  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.2rem;
  }

  .footer-nav a {
    color: var(--ink);
    font-size: 0.95rem;
    font-weight: 500;
  }

  .footer-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.5rem;
    justify-content: space-between;
    margin-top: var(--space-3);
    padding-top: var(--space-2);
    border-top: 1px solid var(--border);
  }
</style>
